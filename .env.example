VITE_API_URL=http://localhost:8000/api
# true = dados mock locais | false = chama o backend em VITE_API_URL
VITE_USE_MOCK=true

# Dev com proxy Vite (evita CORS): use VITE_API_URL=/api e backend em :8000
# VITE_API_URL=/api

# Opcional: ativa OpenAI sem passar pela tela de Configurações
# VITE_OPENAI_API_KEY=sk-...
